HTTP_SERVER_HOST=localhost
HTTP_SERVER_PORT=9000
HTTP_SERVER_READ_TIMEOUT=15
HTTP_SERVER_WRITE_TIMEOUT=15
HTTP_SERVER_IDLE_TIMEOUT=60
HTTP_SERVER_SHUTDOWN_TIMEOUT=15

APP_BASE_URL=http://localhost:9000
APP_NAME=go-online-auction

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=go-online-auction
DB_SSL_MODE=false
DB_PREPARE_STATEMENT=true
DB_ENABLE_LOGS=true
DB_MAX_OPEN_CONNECTIONS=10
DB_MAX_IDLE_CONNECTIONS=10

# NATS
NATS_URL=nats://localhost:4222
NATS_NAME=go-online-auction
NATS_CREDS=
NATS_TLS=false
NATS_MAX_RECONNECTS=60
NATS_RECONNECT_WAIT=2s
NATS_DEDUPE_WINDOW=2m

# Auction scheduler (automatically starts scheduled auctions and closes expired ones)
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL=5s
SCHEDULER_BATCH_SIZE=100

# Transactional outbox relay (delivers domain events to JetStream)
OUTBOX_RELAY_INTERVAL=500ms
OUTBOX_RELAY_BATCH_SIZE=200

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_HOURS=168

# Logger
LOG_ENABLED=true
LOG_LEVEL=info

# CORS settings
CORS_ALLOWED_ORIGINS=*                             # Comma-separated list of allowed origins, or * for all
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS   # Comma-separated list of allowed HTTP methods
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-CSRF-Token  # Comma-separated list of allowed headers
CORS_EXPOSED_HEADERS=Link                          # Comma-separated list of headers that browsers are allowed to access
CORS_ALLOW_CREDENTIALS=false                        # Allow cookies and credentials
CORS_MAX_AGE=300                                   # How long the results of a preflight request can be cached (in seconds)
CORS_OPTIONS_PASSTHROUGH=false                     # Whether to pass OPTIONS requests to handlers
CORS_DEBUG=false  

# Examples for different scenarios:
# For a specific origin:
# CORS_ALLOWED_ORIGINS=https://myapp.com
# For multiple specific origins:
# CORS_ALLOWED_ORIGINS=https://myapp.com,https://admin.myapp.com
# For wildcard subdomains:
# CORS_ALLOWED_ORIGINS=https://*.myapp.com
# For both http and https:
# CORS_ALLOWED_ORIGINS=https://*,http://*  

# Payment provider (deposit escrow): mock (default) or generic HTTP adapter
PAYMENT_PROVIDER=mock
PAYMENT_BASE_URL=
PAYMENT_API_KEY=
PAYMENT_AUTH_HEADER=Authorization
PAYMENT_TIMEOUT=15s
PAYMENT_HOLD_PATH=/v1/holds
PAYMENT_RELEASE_PATH=/v1/holds/release
PAYMENT_CAPTURE_PATH=/v1/holds/capture
PAYMENT_FORFEIT_PATH=/v1/holds/forfeit
